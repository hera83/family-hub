# ──────────────────────────────────────────
# App Mode: "supabase" (default/Lovable) or "local" (self-hosted)
# ──────────────────────────────────────────
VITE_APP_MODE=supabase

# ── Supabase mode (used when VITE_APP_MODE=supabase) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ── Local mode (used when VITE_APP_MODE=local) ──
VITE_API_BASE_URL=/api
VITE_API_KEY=

# ── Backend (only for local/Docker mode) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/familyhub
PORT=3001
API_KEY=
